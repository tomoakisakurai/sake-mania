# Supabase Postgres connection string (Drizzle / postgres-js).
# Supabase dashboard → Project Settings → Database → Connection string → "URI".
# Use the connection pooler URI (port 6543) for the app, e.g.:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# For drizzle-kit push/migrate you may prefer the direct connection (port 5432).
DATABASE_URL=

# (Reserved for a later step — Supabase Auth)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
