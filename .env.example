# Supabase Postgres connection string (Drizzle / postgres-js).
# Supabase dashboard → Project Settings → Database → Connection string → "URI".
# Use the connection pooler URI (port 6543) for the app, e.g.:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# For drizzle-kit push/migrate you may prefer the direct connection (port 5432).
DATABASE_URL=

# Supabase Auth (browser client). Supabase dashboard → Project Settings → API.
#   NEXT_PUBLIC_SUPABASE_URL      = Project URL (https://<ref>.supabase.co)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = anon / public key (公開キーでOK)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI API key (銘柄登録のラベルAI読み取りで使用、gpt-4o-mini)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Slack Incoming Webhook URL (MEETUP/イベント作成時にSlackへ自動投稿)
# https://api.slack.com/messaging/webhooks でチャンネルごとに作成
SLACK_WEBHOOK_URL=

# アプリの公開URL(Slack投稿内のリンクを絶対URLにする用。未設定なら相対パスのまま)
NEXT_PUBLIC_SITE_URL=
